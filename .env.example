# .env.example - copy to .env or .env.local and fill in real values

# Backend API base URL
VITE_API_URL=http://localhost:5000/api

# Google Maps JavaScript API key (required for maps, places, geocoding)
VITE_GOOGLE_MAPS_API_KEY=

# Socket.IO server URL (usually same as API_URL)
VITE_SOCKET_URL=http://localhost:5000

# Public URL of the frontend app (useful for redirects, sharing links)
VITE_APP_URL=http://localhost:5175

# App environment (development / staging / production)
VITE_APP_ENV=development

# ──────────────────────────────────────────────
#  Never commit real secrets!
#  Use .env.local (gitignore'd) for sensitive keys
# ──────────────────────────────────────────────